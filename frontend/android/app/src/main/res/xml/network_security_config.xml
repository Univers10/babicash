<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuration de sécurité réseau pour BabiCash : HTTPS uniquement.

  Pas de certificate pinning : le serveur utilise Let's Encrypt dont les
  certificats (et leurs clés) tournent tous les ~60-90 jours — un pin
  bloquerait l'app à chaque renouvellement. De plus les pins Android
  exigent le SHA-256 du SPKI encodé en base64, pas une empreinte hex.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
